{
  "info": {
    "name": "Go Live Tester — Mobile (Rider + Driver)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Endpoints used by go-live-tester. Set variables: `base_url`, `rider_token`, `driver_token`.\n\n**Rider map preview:** `POST /apimobile/user/map/nearby-drivers` (no booking). **Driver OTP:** set `driver_token` from register response, then **Driver submit OTP** / **Driver send OTP**."
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://nodeteam.site"
    },
    {
      "key": "rider_token",
      "value": ""
    },
    {
      "key": "driver_token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Rider — Auth (no token)",
      "item": [
        {
          "name": "Rider register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/apimobile/user/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test\",\n  \"phone\": \"01234567890\",\n  \"password\": \"Test1234\",\n  \"confirmPassword\": \"Test1234\"\n}"
            }
          }
        },
        {
          "name": "Rider login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/apimobile/user/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"01234567890\",\n  \"password\": \"Test1234\"\n}"
            }
          }
        },
        {
          "name": "Rider resend OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/apimobile/user/auth/resend-otp",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"01234567890\"\n}"
            }
          }
        },
        {
          "name": "Rider submit OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/apimobile/user/auth/submit-otp",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"otp\": \"123456\"\n}"
            }
          }
        }
      ]
    },

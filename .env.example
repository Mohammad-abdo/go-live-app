# API origin (no trailing slash).
#
# **Production build (`npm run build`):** If the SPA is hosted on a different host than the Node API,
# you MUST set this — otherwise the browser requests /apimobile on the static host and gets 404.
# Example API host (root URL may 404; only /apimobile and /api are served):
#   VITE_API_ORIGIN=https://nodeteam.site
#
# **Dev:** leave empty — Vite dev server proxies /apimobile and /api (see VITE_API_PROXY_TARGET).
# **vite preview:** leave empty only if VITE_API_PROXY_TARGET or VITE_API_ORIGIN is set so preview.proxy can forward; or set VITE_API_ORIGIN and build so axios hits the API directly (watch CORS).
#
# **Vercel (go-live-app.vercel.app):** Leave `VITE_API_ORIGIN` empty if `vercel.json` proxies `/apimobile` and `/api`
# to your Node host. If you use a catch-all `/(.*)` → `index.html` without those proxies, POST /apimobile/… returns **405**.
# Change the host in `vercel.json` rewrites if your API is not on nodeteam.site.
VITE_API_ORIGIN=

# Optional: Socket.IO host if not same as the page (Vercel rewrites /apimobile but not /socket.io). On *.vercel.app the app defaults to https://nodeteam.site. Dev: leave empty; vite.config proxies /socket.io.
# VITE_SOCKET_ORIGIN=https://nodeteam.site

# DB seed test users (backend prisma/seed.js): rider 01234567890 / Test1234 — driver 01001234567 / password123

# Fallback only: EGP/km when vehicle-types API returns no `pricingRule`. In production, fares use admin
# **Pricing rules** (`baseFare`, `baseDistance`, `perDistanceAfterBase`, `minimumFare`) from the dashboard.
VITE_TRIP_PRICE_PER_KM=8

# Optional: search radius in km for near-drivers (only sent if the backend reads `radius_km`). Default 15. Set to 0 to omit the field.
VITE_NEAR_DRIVER_SEARCH_RADIUS_KM=15

# Onboarding (Figma MCP URLs in `src/lib/figmaAssets.js` expire ~7d — override with your own CDN)
# VITE_ONBOARDING_IMG_1=
# VITE_ONBOARDING_IMG_2=
# VITE_ONBOARDING_IMG_3=
# VITE_ONBOARDING_PATTERN_1=
# VITE_ONBOARDING_PATTERN_2=
# VITE_ONBOARDING_PATTERN_3=

# Dev + vite preview proxy target (see `vite.config.js` — used when VITE_API_ORIGIN is empty).
# Example remote API:
#   VITE_API_PROXY_TARGET=https://nodeteam.site
# Local Node:
#   VITE_API_PROXY_TARGET=http://127.0.0.1:5000

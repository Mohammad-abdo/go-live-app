{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/apimobile/:path*",
      "destination": "https://nodeteam.site/apimobile/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://nodeteam.site/api/:path*"
    },
    {
      "source": "/socket.io",
      "destination": "https://nodeteam.site/socket.io"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "https://nodeteam.site/socket.io/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}

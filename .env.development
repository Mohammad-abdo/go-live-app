# Dev + `vite preview` proxy: forwards /apimobile and /api to this host (see vite.config.js).
# https://nodeteam.site/ homepage may 404 — that is normal; API is under /apimobile and /api.
# For `npm run build` + deploy elsewhere, set VITE_API_ORIGIN in .env.production (see .env.example).
VITE_API_PROXY_TARGET=https://nodeteam.site
